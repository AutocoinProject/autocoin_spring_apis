# ====================================
# Autocoin Spring API - Environment Template
# ====================================
# Copy this file to .env and fill in the actual values

# ====================================
# Basic Application Settings
# ====================================
SPRING_PROFILES_ACTIVE=local
API_PORT=8080
SERVER_ADDRESS=0.0.0.0
APP_INIT_ENABLED=true

# ====================================
# Database Settings
# ====================================
# For Local Development (Docker MySQL)
DB_URL=jdbc:mysql://localhost:3306/autocoin_db?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_HOST=localhost
DB_PORT=3306
DB_NAME=autocoin_db
DB_USERNAME=root
DB_PASSWORD=password

# For Development Server (RDS)
# DB_URL=jdbc:mysql://your-rds-endpoint:3306/autocoin_db?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=true
# DB_USERNAME=your-db-username
# DB_PASSWORD=your-secure-password

# Hibernate Settings
DDL_AUTO=update
HIBERNATE_BATCH_SIZE=100
HIBERNATE_FORMAT_SQL=true
HIBERNATE_SHOW_SQL=false

# ====================================
# Security Settings
# ====================================
JWT_SECRET=your-jwt-secret-key-at-least-32-characters-long
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000

# ====================================
# OAuth2 Social Login (Optional)
# ====================================
OAUTH2_ENABLED=false
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth2/redirect

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Kakao OAuth2
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# ====================================
# AWS S3 Settings (Optional)
# ====================================
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_REGION=ap-northeast-2
AWS_STACK_AUTO=false

# ====================================
# External APIs (Optional)
# ====================================
# Upbit API
UPBIT_API_URL=https://api.upbit.com
UPBIT_API_TIMEOUT=30000
UPBIT_RATE_LIMIT_ENABLED=true
UPBIT_ENCRYPTION_KEY=your-upbit-encryption-key
UPBIT_WEBSOCKET_URL=wss://api.upbit.com/websocket/v1

# SERP API for news
SERP_API_KEY=your-serp-api-key

# Flask API Integration
FLASK_API_URL=http://localhost:5000
HTTP_CLIENT_CONNECT_TIMEOUT=5000
HTTP_CLIENT_READ_TIMEOUT=30000

# ====================================
# CORS Settings
# ====================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type
CORS_MAX_AGE=3600

# ====================================
# Redis Settings
# ====================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ====================================
# Development Tools
# ====================================
SWAGGER_ENABLED=true
H2_CONSOLE_ENABLED=false
DEVTOOLS_ENABLED=true

# ====================================
# Logging Settings
# ====================================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_AUTOCOIN_USER=DEBUG
LOG_LEVEL_AUTOCOIN_CHART=DEBUG
LOG_LEVEL_AUTOCOIN_AUTH=DEBUG
LOG_LEVEL_AUTOCOIN_TRADING=DEBUG
LOG_LEVEL_AUTOCOIN_FILTER=WARN
LOG_LEVEL_AUTOCOIN_AUTH_FILTER=WARN
LOG_LEVEL_SPRING=WARN
LOG_LEVEL_SPRING_SECURITY=WARN
LOG_LEVEL_SPRING_WEB=WARN
LOG_LEVEL_HIBERNATE=WARN
LOG_LEVEL_HIBERNATE_SQL=WARN
LOG_LEVEL_HIBERNATE_TYPE=WARN
LOG_LEVEL_HIKARI=WARN
LOG_LEVEL_TOMCAT=ERROR
LOG_LEVEL_JETTY=ERROR

# Log File Settings
LOG_FILE_NAME=logs/autocoin-local.log
LOG_FILE_MAX_SIZE=100MB
LOG_FILE_MAX_HISTORY=7

# Log Patterns
LOG_PATTERN_CONSOLE=%d{HH:mm:ss.SSS} %-5level %logger{20} - %msg%n
LOG_PATTERN_FILE=%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%X{traceId:-}] %logger{36} - %msg%n

# Application Logging
AUTOCOIN_LOG_REQUEST_FILTER=false
AUTOCOIN_LOG_API_FILTER=true
AUTOCOIN_LOG_API_FILTER_DETAILED=false

# ====================================
# Notification Settings (Optional)
# ====================================
# Slack Notifications
SLACK_WEBHOOK_URL=your-slack-webhook-url-here
SLACK_NOTIFICATIONS_ENABLED=false
SLACK_ERROR_CHANNEL=#errors
SLACK_ALERT_CHANNEL=#alerts
SLACK_TRADE_CHANNEL=#trades

# ====================================
# Monitoring Settings (Optional)
# ====================================
# Sentry Error Tracking
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=1.0.0
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_DEBUG=true
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ATTACH_STACKTRACE=true
SENTRY_ATTACH_THREADS=false
SENTRY_ENABLE_TRACING=true
SENTRY_MAX_BREADCRUMBS=100
SENTRY_MAX_CACHE_ITEMS=30

# Spring Boot Actuator
MANAGEMENT_ENDPOINTS=health,info,metrics,prometheus
MANAGEMENT_CORS_METHODS=GET,POST
MANAGEMENT_HEALTH_SHOW_DETAILS=when-authorized
MANAGEMENT_HEALTH_SHOW_COMPONENTS=when-authorized
MANAGEMENT_METRICS_ENABLED=true
MANAGEMENT_PROMETHEUS_ENABLED=true
MANAGEMENT_METRICS_APP_NAME=autocoin-api-local

# ====================================
# News Scheduler Settings
# ====================================
NEWS_SCHEDULER_ENABLED=true
NEWS_COLLECT_CRON=0 */30 * * * *
NEWS_CLEANUP_CRON=0 0 */6 * * *
NEWS_MAX_COUNT=20

# ====================================
# Performance Settings
# ====================================
SPRING_TASK_EXECUTION_POOL_CORE_SIZE=4
SPRING_TASK_EXECUTION_POOL_MAX_SIZE=16
SPRING_TASK_EXECUTION_POOL_QUEUE_CAPACITY=50

# ====================================
# File Upload Settings
# ====================================
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB
FILE_SIZE_THRESHOLD=2KB
TOMCAT_MAX_FORM_SIZE=10MB
TOMCAT_MAX_SWALLOW_SIZE=10MB

# ====================================
# Version Information
# ====================================
APP_VERSION=1.0.0-SNAPSHOT
BUILD_TIME=development